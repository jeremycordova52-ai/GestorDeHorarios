package estructuras;

import modelo.Curso;

/**
 * Arreglo estático de objetos Curso.
 * No usa ArrayList ni colecciones predefinidas.
 */
public class ArregloCursos {
    private Curso[] datos;
    private int cantidad;

    public ArregloCursos(int capacidad) {
        datos = new Curso[capacidad];
        cantidad = 0;
    }

    public boolean insertar(Curso curso) {
        if (curso == null || cantidad == datos.length) {
            return false;
        }
        if (buscar(curso.getCodigo()) != null) {
            return false;
        }
        datos[cantidad] = curso;
        cantidad++;
        return true;
    }

    public boolean eliminar(String codigo) {
        int pos = posicion(codigo);
        if (pos == -1) {
            return false;
        }
        for (int i = pos; i < cantidad - 1; i++) {
            datos[i] = datos[i + 1];
        }
        datos[cantidad - 1] = null;
        cantidad--;
        return true;
    }

    public Curso buscar(String codigo) {
        int pos = posicion(codigo);
        if (pos == -1) {
            return null;
        }
        return datos[pos];
    }

    private int posicion(String codigo) {
        for (int i = 0; i < cantidad; i++) {
            if (datos[i].getCodigo().equalsIgnoreCase(codigo)) {
                return i;
            }
        }
        return -1;
    }

    public Curso obtener(int indice) {
        if (indice < 0 || indice >= cantidad) {
            return null;
        }
        return datos[indice];
    }

    public int getCantidad() {
        return cantidad;
    }

    public int getCapacidad() {
        return datos.length;
    }
}
